# Copy to .env for LOCAL runs. NEVER commit your real .env.
# In GitHub Actions these come from repository Secrets instead.

# --- Market data (Yahoo Finance via yfinance — NO API KEY NEEDED) ---
MARKET_DATA_PROVIDER=yfinance

# --- Email (the only notification channel in v1) ---
GMAIL_USER=your_gmail_address
GMAIL_APP_PASSWORD=your_16_digit_gmail_app_password
ALERT_EMAIL_TO=sahabhi115@gmail.com
EMAIL_ENABLED=true

# --- Execution mode (v1 is paper only; do not change in v1) ---
EXECUTION_MODE=paper
BROKER_ADAPTER=paper
LIVE_TRADING_ENABLED=false
ANGEL_ONE_ENABLED=false

# =====================================================================
# FUTURE PLACEHOLDERS — DO NOT SET THESE IN v1.
# Real Angel One trading is intentionally disabled. These are documented
# here only so the future transition is clear. v1 does NOT read them.
# =====================================================================
# ANGEL_ONE_CLIENT_ID=
# ANGEL_ONE_PASSWORD=
# ANGEL_ONE_TOTP_SECRET=
# ANGEL_ONE_API_KEY=
# ANGEL_ONE_FEED_TOKEN=
# ANGEL_ONE_JWT_TOKEN=
